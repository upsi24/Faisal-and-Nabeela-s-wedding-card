<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Walimatul Urus | Faisal & Nabeela</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Montserrat:wght@300;400&family=Amiri:ital@1&display=swap" rel="stylesheet">
    
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        :root {
            --pink-soft: #fce4ec;
            --pink-deep: #f06292;
            --gold: #d4af37;
            --glass: rgba(255, 255, 255, 0.25);
        }

        body, html {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            background: linear-gradient(135deg, #fff5f8 0%, #ffe0e9 100%);
            font-family: 'Montserrat', sans-serif;
            color: #4a4a4a;
        }

        /* 3D Canvas Background */
        #canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }

        /* Container Utama */
        .wrapper {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
            padding: 40px 20px;
            position: relative;
        }

        /* Glassmorphism Card */
        .card {
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 30px;
            padding: 50px 20px;
            box-shadow: 0 8px 32px 0 rgba(240, 98, 146, 0.1);
            margin-bottom: 50px;
        }

        /* Khat & Islamic Elements */
        .khat {
            font-family: 'Amiri', serif;
            font-size: 2.5rem;
            color: var(--pink-deep);
            margin-bottom: 20px;
        }

        .bismillah {
            font-size: 1.2rem;
            margin-bottom: 30px;
            font-style: italic;
        }

        /* Nama Pengantin */
        h1 {
            font-family: 'Great Vibes', cursive;
            font-size: 4rem;
            color: var(--pink-deep);
            margin: 10px 0;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.05);
        }

        .and {
            font-size: 1.5rem;
            color: var(--gold);
            margin: 10px 0;
        }

        /* Fairy Aesthetic Decorations */
        .fairy-light {
            position: absolute;
            width: 5px;
            height: 5px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 0 10px 2px white;
            animation: twinkle 3s infinite;
        }

        @keyframes twinkle {
            0%, 100% { opacity: 0.3; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.5); }
        }

        .details {
            margin: 30px 0;
            line-height: 1.8;
            font-size: 1.1rem;
        }

        .date-box {
            border-top: 1px solid var(--gold);
            border-bottom: 1px solid var(--gold);
            padding: 20px 0;
            margin: 20px 0;
            color: var(--gold);
            font-weight: bold;
            letter-spacing: 2px;
        }

        footer {
            font-size: 0.8rem;
            opacity: 0.7;
            margin-top: 100px;
        }
    </style>
</head>
<body>

    <div id="canvas-container"></div>

    <div class="wrapper">
        
        <div class="card" data-aos="fade-up">
            <div class="khat">بسم الله الرحمن الرحيم</div>
            <div class="bismillah">Dengan Nama Allah Yang Maha Pemurah Lagi Maha Mengasihani</div>
            
            <p>Assalamu’alaikum Warahmatullahi Wabarakatuh</p>
            
            <div class="details">
                Dengan penuh kesyukuran ke hadrat Ilahi, kami menjemput Dato’/Datin/Tuan/Puan/Encik/Cik ke majlis perkahwinan:
            </div>

            <div data-aos="zoom-in" data-aos-delay="300">
                <h1>Faisal</h1>
                <div class="and">&</div>
                <h1>Nabeela</h1>
            </div>

            <div class="date-box" data-aos="fade-right">
                SABTU | 25 JULAI 2026
            </div>

            <div class="details" data-aos="fade-up">
                <p><strong>Lokasi:</strong><br>
                Dewan Melur, Kelantan,<br>
                Malaysia</p>
                
                <p><strong>Aturcara Majlis:</strong><br>
                Jamuan Makan: 11:00 AM - 4:00 PM<br>
                Ketibaan Pengantin: 1:00 PM</p>
            </div>

            <div class="khat" style="font-size: 1.5rem;">بارك الله لكما وبارك عليكما وجمع بينكما في خير</div>
            <p style="font-size: 0.9rem; font-style: italic;">"Semoga Allah memberkati kamu dan menetapkan berkah atasmu, dan mengumpulkan kamu berdua dalam kebaikan."</p>
        </div>

        <footer>
            #FaisalXNabeela #WalimatulUrus
        </footer>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    
    <script>
        // Initialize AOS
        AOS.init({ duration: 1500 });

        // --- Three.js 3D Butterfly Animation ---
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.getElementById('canvas-container').appendChild(renderer.domElement);

        const butterflies = [];
        const butterflyCount = 15;

        // Create a simple Butterfly Geometry
        function createButterfly() {
            const group = new THREE.Group();
            const wingShape = new THREE.Shape();
            wingShape.moveTo(0, 0);
            wingShape.bezierCurveTo(1, 1, 1, 2, 0, 1.5); // Wing curve
            
            const geometry = new THREE.ShapeGeometry(wingShape);
            const material = new THREE.MeshPhongMaterial({ 
                color: 0xffb6c1, 
                side: THREE.DoubleSide,
                transparent: true,
                opacity: 0.8
            });

            const leftWing = new THREE.Mesh(geometry, material);
            const rightWing = new THREE.Mesh(geometry, material);
            
            rightWing.rotation.y = Math.PI;
            
            group.add(leftWing);
            group.add(rightWing);
            
            return group;
        }

        for (let i = 0; i < butterflyCount; i++) {
            const b = createButterfly();
            b.position.set(
                (Math.random() - 0.5) * 10,
                (Math.random() - 0.5) * 10,
                (Math.random() - 0.5) * 5
            );
            b.scale.set(0.2, 0.2, 0.2);
            b.rotation.x = Math.random() * Math.PI;
            
            const speed = 0.02 + Math.random() * 0.03;
            butterflies.push({ mesh: b, speed: speed, phase: Math.random() * Math.PI });
            scene.add(b);
        }

        // Lighting
        const light = new THREE.PointLight(0xffffff, 1, 100);
        light.position.set(0, 0, 10);
        scene.add(light);
        scene.add(new THREE.AmbientLight(0xffffff, 0.5));

        camera.position.z = 5;

        function animate() {
            requestAnimationFrame(animate);

            butterflies.forEach(b => {
                // Flapping wings
                b.phase += 0.2;
                b.mesh.children[0].rotation.y = Math.sin(b.phase) * 0.8;
                b.mesh.children[1].rotation.y = -Math.sin(b.phase) * 0.8;

                // Movement
                b.mesh.position.y += Math.sin(b.phase * 0.1) * 0.01;
                b.mesh.position.x += Math.cos(b.phase * 0.1) * 0.01;
                
                if(b.mesh.position.y > 5) b.mesh.position.y = -5;
            });

            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    </script>
</body>
</html>